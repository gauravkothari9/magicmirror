yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor / IDE
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# Vercel
.vercel/
