# ─── Client Environment Variables ───────────────────────────
# Copy this file to .env.local and fill in your values.
# All variables MUST be prefixed with VITE_ to be exposed to the browser.

# Base URL of your deployed Express backend (no trailing slash).
# Local dev: leave empty — Vite proxy handles /api → http://localhost:5000
# Production: set to your Vercel server URL e.g. https://aura-mirror-server.vercel.app
VITE_API_URL=
